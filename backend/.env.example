PORT=3000

# MongoDB connection string
# For production: use a MongoDB Atlas connection string
# e.g., mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chatflow
MONGODB_URI=mongodb://localhost:27017/chatflow

# Secret key for signing JWT tokens — use a long random string in production
JWT_SECRET=your_secret_key_here

# URL of the frontend (used for CORS)
# For production: set to your Vercel frontend URL, e.g., https://chatflow.vercel.app
CLIENT_URL=http://localhost:3001
