# Frontend environment variables
# Copy this file to .env.local for local development
# Set these as Environment Variables in your Vercel project settings for production

# URL of your deployed backend API (e.g., https://chatflow-backend.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL for Socket.IO connection — should match your backend URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
